[Unit]
Description=KIC Brand Portal API
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/kic-brand-portal
EnvironmentFile=/opt/kic-brand-portal/.env
ExecStart=/usr/bin/node /opt/kic-brand-portal/server/brand/server.js
Restart=always
RestartSec=5
User=pi

[Install]
WantedBy=multi-user.target

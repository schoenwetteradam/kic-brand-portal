# Vercel / local Next.js — public Pi brand API
PI_BASE_URL=https://your-pi-public-url
PI_API_KEY=your_shared_brand_api_key
CRON_SECRET=your_cron_bearer_secret

# Optional: shown in client if used
# NEXT_PUBLIC_APP_NAME=Keeping It Cute Brand Portal

# --- Pi deployment only (kic-brand-api + wix-staff-backend on the Pi) ---
# The Next.js app on Vercel does not need these; they belong on the Pi .env for the brand service.
# WIX_STAFF_API_BASE_URL=http://127.0.0.1:3000
# WIX_STAFF_API_TOKEN=same_as_your_wix_backend_webhook_or_internal_token

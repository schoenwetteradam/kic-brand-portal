# --- Vercel / local Next.js (Next app only) ---
# Public Brand API (production): Cloudflare tunnel / HTTPS — NOT a LAN IP.
PI_BASE_URL=https://brand.yourdomain.com
# Optional alias (same meaning as PI_BASE_URL); useful for local dev:
# PI_API_BASE_URL=http://192.168.1.92:4001
# Sent as header x-api-key (matches server/brand/middleware_api_key.js on the Pi)
PI_API_KEY=your_shared_brand_api_key
CRON_SECRET=your_cron_bearer_secret

# Optional
# NEXT_PUBLIC_APP_NAME=Keeping It Cute Brand Portal
# NEXT_PUBLIC_STAFF_APP_URL=https://wix.keepingitcutesalonandspa.com
# NEXT_PUBLIC_PORTAL_URL=https://portal.keepingitcutesalonandspa.com

# --- Pi: kic-brand-api (server/brand) ---
PORT=4001
DATABASE_URL=postgresql://user:pass@host:5432/brand_db
INTERNAL_API_KEY=your_long_random_key
# or PI_API_KEY=... (either works with middleware_api_key.js)

# Optional OpenAI / brand copy
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5
# BRAND_DEFAULT_CTA=DM us BOOTH to learn more.
# BRAND_NAME=Keeping It Cute Salon & Spa
# BRAND_TAGLINE=Because You Deserve Better

# --- Pi: real salon numbers (pick one or both) ---

# A) Second Postgres URL = Wix staff DB (bookings, inventory_products, …)
# DATABASE_URL_STAFF=postgresql://user:pass@host:5432/staff_db

# B) HTTP bridge to wix-staff-backend (after you add GET /internal/ops/summary)
# WIX_STAFF_API_BASE_URL=http://127.0.0.1:4000
# WIX_STAFF_API_TOKEN=same_as_WEBHOOK_TOKEN_or_internal_Bearer_secret

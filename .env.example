# Vercel / local Next.js — public Pi brand API
PI_BASE_URL=https://your-pi-public-url
# Sent as header x-api-key (matches server/brand/middleware_api_key.js on the Pi)
PI_API_KEY=your_shared_brand_api_key
CRON_SECRET=your_cron_bearer_secret

# Optional: shown in client if used
# NEXT_PUBLIC_APP_NAME=Keeping It Cute Brand Portal

# --- Pi only: kic-brand-api → local Wix staff backend (Docker) ---
# On the Pi, Brand API auth: INTERNAL_API_KEY or PI_API_KEY (either works); clients send x-api-key.
# Vercel / local Next.js do not need these; use /opt/kic-brand-portal/.env on the Pi.
# Staff API is usually host port 4000 (compose: wix_staff_api 4000:4000), not 3000.
# WIX_STAFF_API_BASE_URL=http://127.0.0.1:4000
# WIX_STAFF_API_TOKEN=same_secret_staff_API_uses_for_Bearer_on_/internal/*
